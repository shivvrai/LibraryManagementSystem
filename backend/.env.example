# ── Library Management System — Environment Variables ─────────────────
# Copy this to .env and fill in actual values

# JWT signing key — MUST be a long random string in production
SECRET_KEY=change-me-use-a-long-random-string

# CORS — set to your public server URL on AWS (e.g. http://13.235.50.100)
# Leave empty for local development
EXTRA_CORS_ORIGIN=

# Database connection string
# SQLite (dev):    sqlite:///./library.db
# PostgreSQL:      postgresql://user:password@host:5432/library_db
DATABASE_URL=sqlite:///./library.db

# CORS allowed origins (comma-separated in code, update config.py for production)
# CORS_ORIGINS is set in app/config.py

# Token expiration (minutes) — default: 1440 (24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Fine per day for overdue books (INR)
FINE_PER_DAY=10.0

# Maximum books a student can borrow at once
MAX_BOOKS_PER_STUDENT=3

# Number of days before a book is due
RETURN_DAYS=7

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
